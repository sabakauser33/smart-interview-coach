# MongoDB connection string
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database-name?ssl=true&retryWrites=true&w=majority

# JWT secret for authentication (use a strong random string in production)
JWT_SECRET=your-secret-key-here

# Google GenAI API Key
GOOGLE_GENAI_API_KEY=your-google-genai-api-key

# Optional: Google GenAI model configuration
GOOGLE_GENAI_PRIMARY_MODEL=gemini-1.5-pro
GOOGLE_GENAI_FALLBACK_MODEL=gemini-1.5-flash

# Node environment
NODE_ENV=production

# Frontend URL for CORS
FRONTEND_URL=https://your-frontend.vercel.app

# Port (Render sets this automatically, defaults to 3000)
PORT=3000
